{
	"name": "@nan0web/release",
	"version": "1.0.3",
	"description": "Project Management as Code, Git-Native, GPG-Signed, Test-Driven",
	"main": "src/index.js",
	"types": "types/index.d.ts",
	"type": "module",
	"bin": {
		"nan0release": "./bin/nan0release.js",
		"release": "./bin/nan0release.js"
	},
	"scripts": {
		"build": "tsc",
		"clean": "rm -rf .cache/ && rm -rf dist/",
		"clean:modules": "rm -rf node_modules",
		"test": "node --test \"src/**/*.test.js\"",
		"test1": "node --test \"src/**/*.test.js\" | nan0test parse --fail",
		"test:docs": "node --test \"src/README.md.js\"",
		"test:release": "node --test \"releases/**/*.test.js\"",
		"test:coverage": "node --experimental-test-coverage --test-coverage-include=\"src/**/*.js\" --test-coverage-exclude=\"src/**/*.test.js\" --test \"src/**/*.test.js\"",
		"test:coverage:collect": "nan0test coverage",
		"test:status": "nan0test status",
		"test:all": "npm run test && npm run test:docs && npm run build && npm run knip",
		"test:all1": "npm run test && npm run test:docs && npm run test:status && npm run build",
		"knip": "knip --production",
		"release": "node ./bin/nan0release.js publish",
		"precommit": "npm test",
		"prepush": "npm test",
		"prepare": "husky",
		"playground": "node playground/main.js"
	},
	"dependencies": {
		"@nan0web/changelog": "^1.0.0",
		"@nan0web/co": "^2.0.0",
		"@nan0web/db": "^1.3.3",
		"@nan0web/db-fs": "^1.1.4",
		"@nan0web/log": "^1.1.1",
		"@nan0web/markdown": "^1.0.2",
		"@nan0web/types": "^1.4.0",
		"@nan0web/ui": "^1.8.0",
		"@nan0web/ui-cli": "^2.9.0",
		"@nan0web/verse": "^1.0.0",
		"supports-color": "^10.2.2"
	},
	"devDependencies": {
		"@nan0web/test": "^1.1.3",
		"husky": "^9.1.7",
		"knip": "^5.86.0"
	}
}
